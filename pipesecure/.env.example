# GitHub PAT — needs: repo (clone), issues (read/write), metadata (read)
GITHUB_TOKEN=ghp_your_token_here

# Repo to watch (owner/name)
GITHUB_REPO=216labs/216labs

# Branch to monitor (default: main)
GITHUB_BRANCH=main

# Secret set in the GitHub webhook config (for HMAC signature verification)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: trigger a full scan on container startup
SCAN_ON_STARTUP=false

# Optional: OpenAI key for AI triage (reduces false positives)
# OPENAI_API_KEY=sk-...

# Server port (default: 3000)
PORT=3000

# SQLite data directory (default: /app/data in Docker)
DATA_DIR=./data
