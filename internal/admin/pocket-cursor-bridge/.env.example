# Optional file: any key already set in your shell / launchd / direnv is NOT overwritten.
# Plug-and-play: export TELEGRAM_BOT_TOKEN in your environment and skip this file.
# Or run ./scripts/pocket-cursor-bridge.sh with no token: an interactive wizard writes this file.
#
# Team defaults from admin.6cubed.app → Env (written by scripts/sync-pocket-bridge-env.sh):
#   internal/admin/pocket-cursor-bridge/.env.admin-sync
# That file is merged before this one; this file overrides .env.admin-sync for the same key.
#
# ── Required ─────────────────────────────────────────────────────────
# Create a Telegram bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your numeric Telegram user id — set in admin Env (TELEGRAM_OWNER_ID) and sync, or paste here.
# TELEGRAM_OWNER_ID=123456789
#
# Multiple people (e.g. a family group): comma-separated Telegram user ids. Merged with TELEGRAM_OWNER_ID if set.
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ── Voice: text-to-speech (outgoing) ─────────────────────────────────
# ElevenLabs API key for AI voice replies sent back to Telegram.
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Pronunciation dictionary — fixes mispronounced words (e.g. names across
# languages). Create a PLS file (see scripts/pronunciation.example.pls),
# upload via ElevenLabs API or dashboard, then set these three values.
# ELEVENLABS_PRONUNCIATION_DICT_ID=your-dict-id
# ELEVENLABS_PRONUNCIATION_DICT_VERSION=your-version-id
# ELEVENLABS_PRONUNCIATION_WORD=Michael

# ── Bridge features ──────────────────────────────────────────────────
# Command rules — auto-accept/deny Cursor tool confirmations based on
# allow/deny patterns in lib/command_rules.json. Deny always wins.
# Without this, every confirmation goes to Telegram as usual.
# COMMAND_RULES=true

# Context monitor — annotates your chat input with context window fill level.
# The AI decides what to do with it: save working memory, write a journal
# entry, or just note it. Requires a Cursor rule — see README for setup.
# CONTEXT_MONITOR=true

# Cursor→Telegram: how much of the agent "thinking" block to mirror (pocket_cursor.py).
# Default is verbose (live thinking edits). Override with quiet or normal if needed.
# quiet = skip thinking; normal = full thinking (chunked); verbose = live editMessageText stream.
# POCKETCURSOR_BRIDGE_VERBOSITY=normal
# Or from Telegram: /verbose  /normal  /quiet  (writes .bridge_verbosity beside pocket_cursor.py)

# ── Performance ──────────────────────────────────────────────────────
# Local render directory for phone outbox images. If the repo lives on a
# network drive with high latency (e.g. NAS over VPN), Node.js dependency
# loading can be slow. Point this to a local directory.
# Run: python setup_local_render.py
# RENDER_LOCAL_DIR=Q:\.pocket-cursor\render
