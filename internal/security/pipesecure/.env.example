# GitHub PAT — needs: repo (clone public/private per access), issues (read/write on targets you file into)
GITHUB_TOKEN=ghp_your_token_here

# Single repo (used when GITHUB_REPOS / PIPESECURE_GITHUB_REPOS is empty)
GITHUB_REPO=6cubed/216labs

# Optional: many repos — comma or newline separated; use owner/repo or owner/repo@branch
# PIPESECURE_DRY_RUN=1  # log findings only; do not open or close issues
# PIPESECURE_GITHUB_REPOS=vercel/next.js,facebook/react,expressjs/express,microsoft/vscode,torvalds/linux

# Branch for single-repo mode (default: main). Per-repo branch: owner/repo@my-branch
GITHUB_BRANCH=main

# How often to scan, in hours (default: 24)
SCAN_INTERVAL_HOURS=24

# SQLite data directory (default: /app/data in Docker)
DATA_DIR=./data
