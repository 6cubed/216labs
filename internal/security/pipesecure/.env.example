# GitHub PAT — needs: repo (clone), issues (read/write), metadata (read)
GITHUB_TOKEN=ghp_your_token_here

# Repo to scan (owner/name)
GITHUB_REPO=216labs/216labs

# Branch to scan (default: main)
GITHUB_BRANCH=main

# How often to scan, in hours (default: 24)
SCAN_INTERVAL_HOURS=24

# SQLite data directory (default: /app/data in Docker)
DATA_DIR=./data
