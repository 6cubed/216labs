# 216labs — single VPS deployment config

# Base domain — each app is served at {id}.6cubed.app
# Caddy auto-provisions HTTPS via Let's Encrypt for each subdomain.
APP_HOST=6cubed.app

# Google Analytics 4 — one web stream ID for all public apps (gtag). Compose passes GA_MEASUREMENT_ID into each service.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Optional: numeric property id for admin Analytics deep links (admin container only).
# GA4_PROPERTY_ID=

# Default ./deploy.sh pulls 216labs/* from GHCR (CI: .github/workflows/ghcr-publish.yml) and retags locally.
# Legacy: DEPLOY_IMAGE_SOURCE=local on the machine running deploy.sh builds and streams images over SSH.
COMPOSE_PULL_POLICY=never

# Must match the compose project on the host (directory name under /opt/216labs). Activator uses this so cold-start `docker compose up` targets the same stack as Caddy.
COMPOSE_PROJECT_NAME=216labs

# Activator (showroom): cap evictable running apps; LRU makes room for the one being requested (default 10). Use 0 only to disable eviction (heavy RAM).
# ACTIVATOR_MAX_CONCURRENT_APPS=10
# ACTIVATOR_START_TIMEOUT_SECONDS=240

# ── GHCR (recommended on the droplet: deploy pulls + activator cold-start) ──
# ACTIVATOR_REGISTRY_PREFIX=ghcr.io/6cubed/216labs
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_… (read:packages — classic PAT or a fine-grained token with packages:read)
# Without GHCR_* on the server, deploy still runs but skips registry pull (uses images already on disk).
# You can set GHCR_USERNAME, GHCR_TOKEN, ACTIVATOR_REGISTRY_PREFIX in admin → Environment (216labs.db) instead.

# Admin dashboard basic auth (admin.6cubed.app)
# Generate a hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
# In this file, each literal $ in the bcrypt/PHC string must be doubled ($$) or Docker Compose
# treats $2a etc. as variable substitution and strips the hash — login will always 401.
# Values exported from admin → Environment to .env.admin during deploy.sh are escaped automatically.
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# Optional: if TELEGRAM_CHAT_ID is empty in admin Env, admin startup can seed it (supergroup/channel id).
# Prefer setting TELEGRAM_CHAT_ID in admin → Environment. Do not commit a real id here.
# ADMIN_DEFAULT_TELEGRAM_LOGGING_CHAT_ID=

# Workforce: cron job `workforce-telegram-test` posts as the first employee’s bot to this chat (e.g. supergroup id).
# WORKFORCE_TELEGRAM_CHAT_ID=

# PostgreSQL (used by RamblingRadio)
POSTGRES_USER=labs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ramblingradio
RAMBLINGRADIO_DATABASE_URL=postgresql://labs:changeme@postgres:5432/ramblingradio

# ── PipeSecure ─────────────────────────────────────────────────
PIPESECURE_DATABASE_URL=postgresql://labs:changeme@postgres:5432/pipesecure
PIPESECURE_NEXTAUTH_URL=https://pipesecure.6cubed.app
PIPESECURE_NEXTAUTH_SECRET=generate-a-random-secret-here
PIPESECURE_GITHUB_CLIENT_ID=
PIPESECURE_GITHUB_CLIENT_SECRET=
PIPESECURE_GITHUB_APP_ID=
PIPESECURE_GITHUB_WEBHOOK_SECRET=
PIPESECURE_ENCRYPTION_KEY=generate-64-char-hex-string-here
PIPESECURE_NEXT_PUBLIC_APP_URL=https://pipesecure.6cubed.app

# ── OpenAI (fleet default) ───────────────────────────────────────
# Prefer a single key in admin → Env. Compose passes it into services; optional per-app *_OPENAI_API_KEY overrides.
# OPENAI_API_KEY=

# ── AgitShirts ──────────────────────────────────────────────────
AGITSHIRTS_OPENAI_API_KEY=
AGITSHIRTS_MODEL=gpt-4o-mini
AGITSHIRTS_CHECKOUT_BASE_URL=

# ── Priors ─────────────────────────────────────────────────────
PRIORS_SECRET_KEY=change-me
PRIORS_OAUTH_REDIRECT_URI=https://priors.6cubed.app/callback
PRIORS_GOOGLE_CLIENT_ID=
PRIORS_GEMINI_API_KEY=

# ── OneRoom ─────────────────────────────────────────────────────
# LLM provider for vision analysis: "openai" (default) or "gemini"
# Switch both apps to Gemini by setting provider + Gemini key below.
# Users can also pass their own key via the UI (uses same provider).
ONEROOM_LLM_PROVIDER=openai
ONEROOM_OPENAI_API_KEY=
ONEROOM_GEMINI_API_KEY=

# ── OneFit ───────────────────────────────────────────────────────
ONEFIT_LLM_PROVIDER=openai
ONEFIT_OPENAI_API_KEY=
ONEFIT_GEMINI_API_KEY=

# ── CalibratedAI ───────────────────────────────────────────────
# OpenRouter API key — https://openrouter.ai/keys
CALIBRATEDAI_OPENROUTER_API_KEY=

# ── Big Leroy's PL Guessing Bonanza ────────────────────────────
BIGLEROYS_SECRET_KEY=change-me
BIGLEROYS_OAUTH_REDIRECT_URI=https://bigleroys.6cubed.app/callback
BIGLEROYS_GOOGLE_CLIENT_ID=

# ── Anchor ─────────────────────────────────────────────────────
# JWT secret for signing auth tokens (generate a random string)
ANCHOR_SECRET_KEY=generate-a-random-secret-here
# Radius for nearby posts in metres (default 5000 = 5km)
ANCHOR_RADIUS_METERS=5000

# ── 1PageResearch ──────────────────────────────────────────────
# OpenRouter API key — https://openrouter.ai/keys
ONEPAGE_OPENROUTER_API_KEY=
# LLM model to use (default: google/gemini-flash-1.5)
ONEPAGE_MODEL=google/gemini-flash-1.5

# ── The Zurich Dating Game ──────────────────────────────────────
# Secret key to access admin endpoints (POST /api/admin/match)
ZDGAME_ADMIN_KEY=change-me
# OpenRouter API key for AI matchmaking
ZDGAME_OPENROUTER_API_KEY=
# LLM model for matchmaking (default: google/gemini-2.0-flash-001)
ZDGAME_MODEL=google/gemini-2.0-flash-001

# ── Audio AI Checkup ───────────────────────────────────────────
# OpenAI API key for gpt-4o-audio-preview
AUDIOAICHECKUP_OPENAI_API_KEY=
# Google Gemini API key for gemini-2.0-flash and gemini-1.5-pro
AUDIOAICHECKUP_GEMINI_API_KEY=

# ── Docker Compose (production) ─────────────────────────────────
# deploy.sh exports COMPOSE_PULL_POLICY=never; compose file also sets pull_policy: never per app.

# ── Avatar (LLM + TTS talking head) ─────────────────────────────
AVATAR_OPENAI_API_KEY=
AVATAR_MODEL=gpt-4o-mini
AVATAR_TTS_VOICE=nova

# ── EmailGPT ───────────────────────────────────────────────────
EMAILGPT_RESEND_API_KEY=
EMAILGPT_FROM_EMAIL=
EMAILGPT_CRON_SECRET=
EMAILGPT_OPENAI_API_KEY=

# ── Mediate ──────────────────────────────────────────────────────
MEDIATE_SECRET_KEY=
MEDIATE_OPENAI_API_KEY=
MEDIATE_MODEL=gpt-4o-mini
MEDIATE_BASE_URL=https://mediate.6cubed.app

# ── Impulse ──────────────────────────────────────────────────────
IMPULSE_BASE_URL=https://impulse.6cubed.app

# Deploy script target (optional)
# DEPLOY_HOST=root@your-droplet-ip
# Catalogue cap: how many deploy_enabled apps are considered after priority (default 10). Raise if you need more apps in one deploy run.
# DEPLOY_MAX_APPS=10
#
# Showroom / on-demand demos — droplet keeps only a hot pool running; other apps wake via activator (see docker-compose activator).
# export DEPLOY_SHOWROOM=1
# Space-separated app IDs that stay running and get GHCR-pulled on deploy (default when SHOWROOM=1: admin landing).
# DEPLOY_RUNTIME_APPS="admin landing blog"
