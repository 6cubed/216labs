{
  "id": "1pageresearch",
  "env_prefix": "ONEPAGE",
  "name": "1PageResearch",
  "tagline": "AI-generated one-page research reports",
  "description": "Enter any topic and get a concise, rigorous one-page research report generated by AI — complete with effect sizes, p-values, and source communities.",
  "category": "ai",
  "internal_port": 5000,
  "memory_limit": "128m",
  "docker_service": "1pageresearch",
  "build_context": "./apps/1pageresearch",
  "stack": {
    "frontend": "Flask templates + Jinja2",
    "backend": "Flask + Python + Gunicorn",
    "database": "SQLite",
    "other": ["OpenRouter API", "Server-Sent Events"]
  },
  "env_vars": [
    { "key": "ONEPAGE_OPENROUTER_API_KEY", "description": "1PageResearch OpenRouter API key", "is_secret": true },
    { "key": "ONEPAGE_MODEL", "description": "1PageResearch model name (default: google/gemini-2.0-flash-001)", "is_secret": false },
    { "key": "ONEPAGE_STRIPE_SECRET_KEY", "description": "Stripe secret key for €1 report payments", "is_secret": true },
    { "key": "ONEPAGE_STRIPE_WEBHOOK_SECRET", "description": "Stripe webhook signing secret for /api/webhook/stripe", "is_secret": true },
    { "key": "ONEPAGE_ADMIN_SECRET", "description": "Secret for /admin/requests (approve/deny free reports)", "is_secret": true },
    { "key": "ONEPAGE_BASE_URL", "description": "Base URL for Stripe success/cancel (default: https://1pageresearch.6cubed.app)", "is_secret": false }
  ]
}
